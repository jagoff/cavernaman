    {
      "type": "text", "id": "ev_normal_t", "x": 76, "y": 376, "width": 328, "height": 118,
      "text": "\"The reason your React component\nis re-rendering is likely because\nyou're creating a new object\nreference on each render cycle.\nWhen you pass an inline object\nas a prop... I'd recommend useMemo.\"",
      "originalText": "\"The reason your React component\nis re-rendering is likely because\nyou're creating a new object\nreference on each render cycle.\nWhen you pass an inline object\nas a prop... I'd recommend useMemo.\"",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#cbd5e1", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100021, "version": 1, "versionNonce": 100022, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": "ev_normal", "lineHeight": 1.25
    },

    {
      "type": "rectangle", "id": "ev_cave", "x": 460, "y": 360, "width": 360, "height": 150,
      "strokeColor": "#047857", "backgroundColor": "#1e293b", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 100023, "version": 1, "versionNonce": 100024, "isDeleted": false, "groupIds": [],
      "boundElements": [{"id": "ev_cave_t", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3}
    },
    {
      "type": "text", "id": "ev_cave_t", "x": 476, "y": 400, "width": 328, "height": 70,
      "text": "\"New object ref each render.\nInline object prop = new ref\n= re-render. Wrap in useMemo.\"",
      "originalText": "\"New object ref each render.\nInline object prop = new ref\n= re-render. Wrap in useMemo.\"",
